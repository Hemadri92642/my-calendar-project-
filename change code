import java.time.LocalDate;
import java.time.temporal.IsoFields;
import java.util.HashMap;
import java.util.Map;

class year_month_week {
     class static void main(String[] args) {
        // Change this to the desired year
        int year = 2026;

        Map<Integer, Map<Integer, Map<Integer, Integer>>> yearMap = new HashMap<>();

        for (int month = 1; month <= 10; month++) {
            Map<Integer, Map<Integer, Integer>> monthMap = new HashMap<>();
            for (int week = 1; week <= LocalDate.of(year, month, 1).lengthOfMonth() / 7 + 1; week++) {
                Map<Integer, Integer> weekMap = new HashMap<>();
                weekMap.put(week, LocalDate.of(year, month, 1).plusWeeks(week - 1).getDayOfMonth());
                monthMap.put(week, weekMap);
            }
            yearMap.put(month, monthMap);
        }
        System.out.println(yearMap);
    }
}
